# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL / Aurora RDS)
# For Local Docker: postgresql://postgres:postgres@localhost:5432/production_planning?schema=public
# For Aurora RDS: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/production_planning?schema=public"

# JWT Secret (If used later)
JWT_SECRET=your_jwt_secret_here
